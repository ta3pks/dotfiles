{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npm install:*)",
      "Bash(nc:*)",
      "Bash(test:*)",
      "Bash(node:*)",
      "Bash(npm run dev)",
      "Bash(cargo test:*)",
      "Bash(curl:*)",
      "Bash(npm run test:*)",
      "mcp__web-search-prime__webSearchPrime",
      "mcp__web-reader__webReader",
      "Bash(cargo install:*)",
      "Bash(mdbook build:*)",
      "Bash(npm run check:*)",
      "Bash(npm run build:*)",
      "Bash(git status:*)",
      "Bash(pkill:*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/nikos/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-code-wakatime@wakatime": true,
    "claude-memory-plugin@enhance": true,
    "frontend-design@claude-code-plugins": true
  },
  "extraKnownMarketplaces": {},
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true
}
