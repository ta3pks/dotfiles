{
	"pullDiagnostic.onSave": true,
	"pullDiagnostic.workspace": true,
	"suggest.removeDuplicateItems": true,
	"signature.enable": true,
	"diagnostic.messageTarget": "float",
	"diagnostic.virtualTextCurrentLineOnly": false,
	"coc.preferences.formatOnSave": true,
	"diagnostic.virtualText": true,
	"diagnostic.locationlistLevel": "error",
	"diagnostic.locationlistUpdate": true,
	"coc.preferences.useQuickfixForLocations": true,
	"coc.preferences.enableMessageDialog": true,
	"coc.source.buffer.ignoreGitignore": true,
	"rust-analyzer.check.command": "clippy",
	"rust-analyzer.workspace.symbol.search.kind": "all_symbols",
	"rust-analyzer.workspace.symbol.search.limit": 128,
	"rust-analyzer.workspace.symbol.search.scope": "workspace_and_dependencies",
	"rust-analyzer.cargo.features": "all",
	"rust-analyzer.check.features": "all",
	"rust-analyzer.cargo.buildScripts.enable": true,
	"rust-analyzer.check.allTargets": true,
	"rust-analyzer.procMacro.enable": true,
	"rust-analyzer.diagnostics.disabled": [
		"inactive-code"
	],
	"Lua.runtime.version": "LuaJIT",
	"Lua.workspace.library": [
		"/opt/homebrew/Cellar/neovim/0.9.4/share/nvim/runtime"
	],
	"coc.preferences.extensionUpdateCheck": "daily",
	"svelte.enable-ts-plugin": true,
	"languageserver": {
		"elmLS": {
			"command": "elm-language-server",
			"filetypes": [
				"elm"
			],
			"rootPatterns": [
				"elm.json"
			]
		}
	},
	"emmet.includeLanguages": {
		"html": "svelte"
	},
	// "codeLens.enable": true,
	"inlayHint.enable": true
}
